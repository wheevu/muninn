{
  "name": "muninn-language",
  "displayName": "Muninn Language Support",
  "description": "Thin VS Code integration for the Muninn language server",
  "version": "0.1.0",
  "publisher": "muninn",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:muninn"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "muninn",
        "aliases": [
          "Muninn",
          "muninn"
        ],
        "extensions": [
          ".mun"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "muninn",
        "scopeName": "source.muninn",
        "path": "./syntaxes/muninn.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Muninn",
      "properties": {
        "muninn.serverPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the muninn-lsp binary. If empty, the extension tries target/debug, then cargo run in the workspace, then PATH."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.2",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wheevu/muninn.git"
  }
}
