fn add(a: Int, b: Int) -> Int {
    return a + b;
}

fn countdown(start: Int) -> Int {
    let mut current: Int = start;
    while (current > 0) {
        print(current);
        current = current - 1;
    }
    return current;
}

let final_value: Int = countdown(add(2, 1));
print(final_value);
final_value;
